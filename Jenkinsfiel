pipeline {

    agent any

    tools {
        maven 'maven'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git 'https://github.com/Ajinkm/maven-repo.git'
            }
        }

        stage('Build and Deploy') {
            steps {

                configFileProvider([configFile(fileId: 'maven-settings', variable: 'MAVEN_SETTINGS')]) {

                    sh '''
                    mvn clean deploy --settings $MAVEN_SETTINGS
                    '''

                }

            }
        }

    }

}
